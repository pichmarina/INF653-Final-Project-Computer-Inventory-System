<section class="page-stack">
  <div class="section-heading">
    <div>
      <div class="eyebrow">REQUIREMENT MODULE</div>
      <h1>{{title}}</h1>
      <p>
        Assign available assets to users, return them to inventory, and upload
        reference or inspection documents.
      </p>
    </div>
    <span class="panel-chip">Transaction Module</span>
  </div>

  <div class="panel-grid">
    <div class="glass-card form-panel">
      <div class="panel-title-wrap">
        <h2>Business rules</h2>
      </div>

      <ul class="friendly-list">
        <li>Only Available items should be assigned</li>
        <li>Maintenance and Retired items cannot be checked out</li>
        <li>Check-out must support document upload</li>
        <li>Check-in must return item status to Available</li>
      </ul>
    </div>

    <div class="glass-card table-panel">
      <div class="panel-title-wrap">
        <h2>Coming from Person 2</h2>
        <span class="panel-chip">Backend + UI</span>
      </div>

      <div class="empty-state">
        <h3>Transaction feature placeholder</h3>
        <p>
          This page will later include check-out forms, check-in forms, file upload,
          and assignment workflow connected to the database.
        </p>
      </div>
    </div>
  </div>
</section>